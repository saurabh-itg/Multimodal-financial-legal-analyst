# --- LLM ---
# Provider: "ollama" (default, fully local open-source) | "openai" | "azure" | "anthropic"
LLM_PROVIDER=ollama

# Open-source defaults served by Ollama (https://ollama.com).
# Pull these once with: ollama pull qwen2.5-coder:7b minicpm-v nomic-embed-text
LLM_MODEL=qwen2.5-coder:7b
LLM_VISION_MODEL=minicpm-v
EMBEDDING_MODEL=nomic-embed-text

# Ollama serves an OpenAI-compatible API at /v1.
# Inside docker-compose this is http://ollama:11434/v1
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_REQUEST_TIMEOUT=600

# --- OpenAI / Azure / OpenAI-compatible (only used when LLM_PROVIDER != ollama) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=

# --- Vector store ---
CHROMA_PERSIST_DIR=./.chroma
COLLECTION_NAME=analyst_corpus

# --- Guardrails ---
GROUNDING_MIN_SCORE=0.55
NLI_MODEL=cross-encoder/nli-deberta-v3-base
ENABLE_NLI=true

# --- Service ---
MAX_FILE_MB=50
LOG_LEVEL=INFO
APP_ENV=dev
